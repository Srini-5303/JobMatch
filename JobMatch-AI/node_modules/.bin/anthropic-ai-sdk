#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../.deno/@anthropic-ai+sdk@0.54.0/node_modules/@anthropic-ai/sdk/bin/cli" "$@"
else
  exec node  "$basedir/../.deno/@anthropic-ai+sdk@0.54.0/node_modules/@anthropic-ai/sdk/bin/cli" "$@"
fi
