#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../.deno/pdf-parse@2.4.5/node_modules/pdf-parse/bin/cli.mjs" "$@"
else
  exec node  "$basedir/../.deno/pdf-parse@2.4.5/node_modules/pdf-parse/bin/cli.mjs" "$@"
fi
